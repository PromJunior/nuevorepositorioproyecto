# ── Base de datos ─────────────────────────────────────────────────────────────
# SQL Server con autenticación SQL
DATABASE_URL=mssql+pyodbc://<usuario>:<password>@<host>/<db>?driver=ODBC+Driver+17+for+SQL+Server

# ── Servicios externos ────────────────────────────────────────────────────────
# Token de la API de APIPeru (consulta RUC/DNI)
APIPERU_TOKEN=

# ── Autenticación M2M para n8n ────────────────────────────────────────────────
# Secreto compartido para que n8n llame a /exports/daily-run y /exports/upload
# sin necesitar un JWT de usuario.
#
# Genera un valor seguro con:
#   python -c "import secrets; print(secrets.token_hex(32))"
#
# Configura el mismo valor en el nodo HTTP Request de n8n:
#   Header name:  X-N8N-Secret
#   Header value: <el mismo valor>
N8N_SERVICE_SECRET=

# ── Autenticación n8n (legacy — mantener si se usa X-API-Key) ─────────────────
# ERP_DAILY_BACKUP_API_KEY=
